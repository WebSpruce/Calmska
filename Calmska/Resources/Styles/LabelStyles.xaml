<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="Calmska.Resources.Styles.LabelStyles">
    
    <Style x:Key="SmallInfinity" TargetType="Label">
        <Setter Property="FontSize" Value="Small"/>
        <Setter Property="FontFamily" Value="MADEINFINITYRegular"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>
    
    <Style x:Key="LargeCanelaBlack" TargetType="Label">
        <Setter Property="FontSize" Value="Large"/>
        <Setter Property="FontFamily" Value="CanelaBlack"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>
    <Style x:Key="LargeCanelaRegular" TargetType="Label">
        <Setter Property="FontSize" Value="Large"/>
        <Setter Property="FontFamily" Value="CanelaRegular"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>
    <Style x:Key="LargeTipsInfinityIsExpanded" TargetType="Label">
        <Setter Property="FontSize" Value="Large"/>
        <Setter Property="FontFamily" Value="MADEINFINITYMedium"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>
    <Style x:Key="LargeTipsInfinityIsNotExpanded" TargetType="Label" BasedOn="{StaticResource LargeTipsInfinityIsExpanded}">
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
    </Style>
    
    <Style x:Key="MaterialIconsLarge" TargetType="Label">
        <Setter Property="FontSize" Value="Large" />
        <Setter Property="FontFamily" Value="MaterialIcons"/>
        <Setter Property="TextColor" Value="White" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>
    <Style x:Key="MaterialIconsSmall" TargetType="Label">
        <Setter Property="FontSize" Value="Small" />
        <Setter Property="FontFamily" Value="MaterialIcons"/>
        <Setter Property="TextColor" Value="White" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>
    
</ResourceDictionary>